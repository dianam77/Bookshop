@model Core.BookService.BookDto

@{
    ViewData["Title"] = "Edit";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-r from-blue-300 via-pink-200 to-blue-400 min-h-screen">

    <div class="container mx-auto p-6">
        <h1 class="text-4xl font-extrabold text-center text-black-50 mb-8">ویرایش کتاب</h1>

        <form asp-action="Edit" enctype="multipart/form-data" class="bg-white shadow-xl rounded-xl p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title" class="block text-lg font-semibold text-gray-700">عنوان</label>
                <input asp-for="Title" class="form-control mt-2 p-3 border-2 border-blue-300 rounded-lg shadow-md focus:ring-4 focus:ring-blue-500" />
                <span asp-validation-for="Title" class="text-red-500"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="block text-lg font-semibold text-gray-700">توضیحات</label>
                <input asp-for="Description" class="form-control mt-2 p-3 border-2 border-blue-300 rounded-lg shadow-md focus:ring-4 focus:ring-blue-500" />
                <span asp-validation-for="Description" class="text-red-500"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price" class="block text-lg font-semibold text-gray-700">قيمت</label>
                <input asp-for="Price" class="form-control mt-2 p-3 border-2 border-blue-300 rounded-lg shadow-md focus:ring-4 focus:ring-blue-500" />
            </div>

            <div class="form-group">
                <img src="@Url.Content(Model.ImgName)" width="200px" alt="Book Image" class="rounded-md shadow-lg border-4 border-blue-500" />
                <label asp-for="Img" class="block text-lg font-semibold text-gray-700">تصویر</label>
                <input type="file" asp-for="Img" class="form-control mt-2 p-3 border-2 border-blue-300 rounded-lg shadow-md focus:ring-4 focus:ring-blue-500" />
                <span asp-validation-for="Img" class="text-red-500"></span>
            </div>

            <div class="form-group">
                <label asp-for="AuthorId" class="block text-lg font-semibold text-gray-700">نویسنده</label>
                <select asp-for="AuthorId" class="form-control mt-2 p-3 border-2 border-blue-300 rounded-lg shadow-md focus:ring-4 focus:ring-blue-500" asp-items="ViewBag.AuthorId"></select>
                <span asp-validation-for="AuthorId" class="text-red-500"></span>
            </div>

            <div class="form-group flex items-center space-x-4">
                <div>
                    <label class="control-label text-lg font-semibold text-gray-700">در دسترس</label>
                    <input asp-for="IsAvail" class="form-check-control mt-2" />
                </div>
                <div>
                    <label class="control-label text-lg font-semibold text-gray-700">نمایش در صفحه اصلی</label>
                    <input asp-for="ShowHomePage" class="form-check-control mt-2" />
                </div>
            </div>

            <div class="form-group">
                <input type="submit" value="ذخیره" class="btn px-6 py-3 bg-gradient-to-r from-pink-500 to-blue-500 hover:bg-gradient-to-l text-white font-semibold rounded-lg shadow-md w-full transition duration-300 ease-in-out transform hover:scale-105" />
            </div>
        </form>

        <div class="mt-6">
            <a asp-action="Index" class="text-black-50 hover:text-yellow-300 text-lg transition duration-200">بازگشت به لیست</a>
        </div>

    </div>
    <br />
    <br />
</body>
</html>
